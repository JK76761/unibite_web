{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/unibite.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Overpass": {
    "EndpointUrl": "https://overpass-api.de/api/interpreter",
    "SearchRadiusMeters": 1800,
    "RequestTimeoutSeconds": 25
  },
  "GooglePlaces": {
    "ApiKey": "",
    "TextSearchEndpoint": "https://places.googleapis.com/v1/places:searchText",
    "PlacePhotosEndpointBase": "https://places.googleapis.com/v1/",
    "RequestTimeoutSeconds": 12,
    "PhotoMaxWidthPx": 960,
    "SearchRadiusMeters": 250
  },
  "AdminSecurity": {
    "ApiKey": "",
    "HeaderName": "X-Admin-Key"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
